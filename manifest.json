{
    "manifest_version": 2,
    "name": "AI to AI 😏",
    "version": "1.0",
    "description": "Replaces instances of 'AI' and 'A.I.' with 'artificial insemination' while preserving case sensitivity",
    "browser_specific_settings": {
    "gecko": {
      "id": "@aitoartificialinsemination",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
    "icons": {
      "48": "icons/butt-48.png",
      "96": "icons/butt-96.png"
    },
    
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["replace.js"]
      }
    ]
  }
